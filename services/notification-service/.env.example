ENV=development
PORT=8086
GRPC_PORT=50056

DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecocomply
DB_USER=postgres
DB_PASSWORD=secret

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

JWT_SECRET=ecocomply-ng-dev-jwt-secret-2026-rotate-before-prod
JWT_EXPIRY_HOURS=24
JWT_ISSUER=auth.ecocomply.ng
JWT_AUDIENCE=notification-service

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications.ecocomply@gmail.com
SMTP_PASSWORD=gmail-app-password-16chars
FROM_ADDRESS=noreply@ecocomply.ng
TEMPLATE_PATH=./internal/email/templates
